{
  "name": "motionlang",
  "version": "1.0.0",
  "description": "Extract the complete motion language from any website — scroll animations, GSAP timelines, Framer Motion variants, transitions, and more. Outputs structured motion spec, GSAP code, Framer Motion code, CSS, Figma tokens, and MCP resource.",
  "type": "module",
  "bin": {
    "motionlang": "./bin/motionlang.js"
  },
  "main": "src/index.js",
  "scripts": {
    "start": "node bin/motionlang.js",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.0",
    "playwright": "^1.42.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "motion",
    "animation",
    "design-tokens",
    "gsap",
    "framer-motion",
    "css-animations",
    "playwright",
    "design-system",
    "figma",
    "mcp"
  ],
  "author": "",
  "license": "MIT"
}